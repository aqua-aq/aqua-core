sub Range(max)
    it.max = max
with {
    current: 0,
    sub next() 
        if it.current >= it.max 
            raise: stop
        end
        let current = it.current
        it.current++
        return: current
    end,
    sub __iter__() 
        return: it.>next
    end
}

for i in Range(10)
    println(i)
end